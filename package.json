{
  "name": "playwright-typescript-playwright-test",
  "version": "1.0.0",
  "description": "Scroll Finance Automation Framework",
  "main": "index.js",
  "scripts": {
    "ENV": "export npm_config_ENV=$env",
    "test_": "npx playwright test $TEST_FILE --project=Chrome",
    "test:mac": "ENV=$ENV TEST_FILE=$TEST_FILE npx playwright test $TEST_FILE --project=Chrome ",
    "test:window": "set TEST_FILE=%TEST_FILE% && npx playwright test %TEST_FILE% --project=Chrome",
    "test:single": "npx playwright test Login.test.ts --project=Chrome",
    "test:parallel": "npx playwright test --grep @Smoke --project=Chrome",
    "test:serial": "npx playwright test --grep @Smoke --workers=1 --project=Chrome",
    "test:ui": "npx playwright test --grep @Smoke --ui",
    "test:api": "npx playwright test --grep @API --workers=1 --project=Chrome",
    "test:db": "npx playwright test DB.test.ts --project=DB",
    "test:record": "npx playwright codegen",
    "test:visual": "npx playwright test visualComparision.test.ts --project=Chrome",
    "test:device": "npx playwright test Emulation.test.ts --project=Device",
    "allureReport": "allure serve",
    "lighthouse": "node tests/lighthouse/Lighthouse.mjs",
    "test:accessibility": "npx playwright test Axe.test.ts --project=Chrome",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^10.0.0",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "allure-playwright": "^3.0.1",
    "cheerio": "^1.0.0",
    "crypto-js": "^4.2.0",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.7",
    "es6-promise": "^4.2.8",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "exceljs": "^4.4.0",
    "fs": "^0.0.1-security",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "html-to-text": "^9.0.5",
    "imap-simple": "^1.6.3",
    "json5": "^2.2.3",
    "lighthouse": "^12.2.2",
    "mailparser": "^3.9.1",
    "mssql": "^11.0.1",
    "mysql2": "^3.14.1",
    "nodemailer": "^7.0.12",
    "ortoni-report": "^2.0.3",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist-es5": "^2.13.216",
    "pg": "^8.13.0",
    "playwright": "^1.50.1",
    "properties-reader": "^2.3.0",
    "quoted-printable": "^1.0.1",
    "read-excel-file": "^5.8.6",
    "soft-assert": "^0.2.7",
    "tedious": "^18.6.1",
    "winston": "^3.14.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.0.3",
    "@wdio/cli": "^9.20.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/types": "^9.20.0",
    "cross-env": "^10.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
