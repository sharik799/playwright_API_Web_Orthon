{
  "compilerOptions": {
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",

    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pageFactory/pageRepository/*"],
      "@objects/*": ["pageFactory/objectRepository/*"],
      "@lib/*": ["lib/*"]
    },

    "lib": ["es6", "dom"]
  }
}

